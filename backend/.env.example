# Copy to .env and adjust. All values are optional for Phase 1 (mock mode).

# General
APP_NAME="AI Trading Assistant"
ENVIRONMENT=development

# Database (SQLite by default; swap for Postgres in production)
DATABASE_URL=sqlite:///./aitrading.db
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/aitrading

# Data mode: keep true until live providers are implemented + keys are set.
USE_MOCK_DATA=true

# --- External provider keys (placeholders; leave blank to stay in mock mode) ---
FX_API_KEY=
MARKET_DATA_API_KEY=
FRED_API_KEY=
NEWS_API_KEY=
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
