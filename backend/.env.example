# Copy to .env and adjust. All values are optional for Phase 1 (mock mode).

# General
APP_NAME="AI Trading Assistant"
ENVIRONMENT=development

# Database (SQLite by default; swap for Postgres in production)
DATABASE_URL=sqlite:///./aitrading.db
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/aitrading

# Data mode: set to false to attempt live data (requires the relevant API key).
# If a live fetch fails or a key is missing, the API degrades to mock data and
# tags the snapshot source as "fallback".
USE_MOCK_DATA=true

# --- FX / USD/MXN live data ---
# Live USD/MXN is fetched when USE_MOCK_DATA=false AND FX_API_KEY is set.
# Default provider: Open Exchange Rates (https://openexchangerates.org).
# Get a free App ID and put it here.
FX_API_KEY=
FX_PROVIDER=openexchangerates
# Optional: override the FX endpoint (defaults to OXR latest.json).
FX_BASE_URL=
HTTP_TIMEOUT_SECONDS=8.0

# --- News (Phase 3 live provider) ---
# Live news is used only when NEWS_API_KEY is set AND USE_MOCK_DATA=false.
# Initial live provider: NewsAPI.org (https://newsapi.org). Get a free key.
# On any failure or missing key, the service falls back to mock news.
NEWS_API_KEY=
NEWS_PROVIDER=newsapi          # newsapi | finnhub (future) | fmp (future)
NEWS_BASE_URL=                 # optional override of the news endpoint

# --- Economic calendar (Phase 3 live provider) ---
# Live calendar is used only when CALENDAR_API_KEY is set AND USE_MOCK_DATA=false.
# Initial live provider: Trading Economics (https://tradingeconomics.com).
# On any failure or missing key, the service falls back to mock events.
CALENDAR_API_KEY=
CALENDAR_PROVIDER=tradingeconomics   # tradingeconomics | finnhub (future)
CALENDAR_BASE_URL=             # optional override of the calendar endpoint

# --- Signal weighting engine ---
# Optional override of the default signal weights (services/signal_weights.py),
# as a JSON object. Unknown keys are ignored. Example: weight DXY and oil down.
# SIGNAL_WEIGHTS={"dxy": 9, "oil": 6, "us_cpi": 10}
SIGNAL_WEIGHTS=

# --- Other external provider keys (placeholders; leave blank for mock) ---
MARKET_DATA_API_KEY=
FRED_API_KEY=
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
