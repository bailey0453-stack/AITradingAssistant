# Copy to .env and adjust. All values are optional for Phase 1 (mock mode).

# General
APP_NAME="AI Trading Assistant"
ENVIRONMENT=development

# Database (SQLite by default; swap for Postgres in production)
DATABASE_URL=sqlite:///./aitrading.db
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/aitrading

# Data mode: set to false to attempt live data (requires the relevant API key).
# If a live fetch fails or a key is missing, the API degrades to mock data and
# tags the snapshot source as "fallback".
USE_MOCK_DATA=true

# --- FX / USD/MXN live data ---
# Live USD/MXN is fetched when USE_MOCK_DATA=false AND FX_API_KEY is set.
# Default provider: Open Exchange Rates (https://openexchangerates.org).
# Get a free App ID and put it here.
FX_API_KEY=
FX_PROVIDER=openexchangerates
# Optional: override the FX endpoint (defaults to OXR latest.json).
FX_BASE_URL=
HTTP_TIMEOUT_SECONDS=8.0

# --- Macro indicators (live, per field) ---
# FRED supplies US 2Y / 10Y yields; Alpha Vantage supplies oil + gold (DXY/VIX/
# S&P have no clean free endpoint and fall back to mock). Each field degrades
# independently. Fetches are cached MACRO_CACHE_SECONDS to respect rate limits
# (Alpha Vantage free tier is ~25 requests/day).
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
MACRO_CACHE_SECONDS=600

# --- News (live provider) ---
# Live news is used only when NEWS_API_KEY is set AND USE_MOCK_DATA=false.
# Providers: NewsAPI.org (newsapi) or Finnhub (finnhub). Items are filtered to
# USD/MXN-relevant topics; on any failure or missing key, falls back to mock.
NEWS_API_KEY=
NEWS_PROVIDER=newsapi          # newsapi | finnhub | fmp (future)
NEWS_BASE_URL=                 # optional override of the news endpoint

# --- Economic calendar (Phase 3 live provider) ---
# Live calendar is used only when CALENDAR_API_KEY is set AND USE_MOCK_DATA=false.
# Initial live provider: Trading Economics (https://tradingeconomics.com).
# On any failure or missing key, the service falls back to mock events.
CALENDAR_API_KEY=
CALENDAR_PROVIDER=tradingeconomics   # tradingeconomics | finnhub (future) | csv
CALENDAR_BASE_URL=             # optional override of the calendar endpoint
# Importable calendar CSV (used when CALENDAR_PROVIDER=csv; no API key needed).
CALENDAR_CSV_PATH=

# --- Market hours + refresh policies (Phase 5.1) ---
# Per-provider refresh cadence override in MINUTES (JSON). Defaults live in
# services/cache_manager.py (USD/MXN 60m market-gated, news 5m, calendar 30m,
# treasury/DXY/gold/oil/VIX 15m). USD/MXN is never requested while closed.
# REFRESH_POLICIES={"usdmxn": 30, "news": 10}
REFRESH_POLICIES=
# FX market holidays (full-day closures) as a JSON list of ISO dates. The
# weekend schedule (Fri 21:00–Sun 21:00 UTC) always applies regardless.
# MARKET_HOLIDAYS=["2026-01-01", "2026-12-25"]
MARKET_HOLIDAYS=

# --- Scheduled jobs (cron) ---
# Shared secret protecting POST/GET /jobs/* . Vercel Cron automatically sends it
# as "Authorization: Bearer <CRON_SECRET>". Set the SAME value here and in the
# Vercel project env. When unset, job endpoints are rejected in production and
# allowed only in mock/dev mode (USE_MOCK_DATA=true) for local runs.
# The hourly USD/MXN job is scheduled in vercel.json ("0 * * * *", UTC); it
# skips generation (and burns no FX quota) when the market is closed.
# Also used by the dashboard research import panel (POST /admin/research/import/*).
# Optional dedicated admin secret; falls back to CRON_SECRET when unset.
ADMIN_SECRET=
CRON_SECRET=

# --- Signal weighting engine ---
# Optional override of the default signal weights (services/signal_weights.py),
# as a JSON object. Unknown keys are ignored. Example: weight DXY and oil down.
# SIGNAL_WEIGHTS={"dxy": 9, "oil": 6, "us_cpi": 10}
SIGNAL_WEIGHTS=

# --- Historical intelligence engine (Phase 4) ---
# Which importer seeds the historical backfill. The default "mock" uses the
# built-in sample dataset (no API key, no network). Real providers are stubs
# until wired in: csv | yahoo | fred | alphavantage | polygon.
HISTORY_IMPORTER=mock
# Optional JSON overrides (unknown keys ignored). Defaults live in the history
# services. SIMILARITY_WEIGHTS tunes "find events like this"; CONFIDENCE_WEIGHTS
# tunes how signal/historical/regime/volatility/data-quality blend.
# SIMILARITY_WEIGHTS={"regime": 0.25, "event_type": 0.2, "vix": 0.15}
SIMILARITY_WEIGHTS=
# CONFIDENCE_WEIGHTS={"signal": 0.5, "historical": 0.2, "regime": 0.15, "volatility": 0.1, "data_quality": 0.05}
CONFIDENCE_WEIGHTS=

# --- Other external provider keys (placeholders; leave blank for mock) ---
MARKET_DATA_API_KEY=
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
