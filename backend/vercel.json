{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "app/**" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/jobs/hourly-usdmxn-analysis",
      "schedule": "0 * * * *"
    },
    {
      "path": "/jobs/research-import-continue",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/jobs/daily-research-update",
      "schedule": "0 23 * * 1-5"
    }
  ]
}
